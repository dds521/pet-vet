{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/tmp"
      ]
    },
    "trendradar": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-trends-hub@latest"
      ]
    },
    "deepwiki": {
      "transportType": "http",
      "url": "https://mcp.deepwiki.com/mcp"
    }
  }
}
